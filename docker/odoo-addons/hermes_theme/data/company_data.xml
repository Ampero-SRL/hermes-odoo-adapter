<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Update main company -->
        <record id="base.main_company" model="res.company">
            <field name="name">HERMES Manufacturing Demo</field>
            <field name="email">demo@hermes-manufacturing.local</field>
            <field name="website">https://hermes-manufacturing.demo</field>
            <field name="company_details">
Advanced Manufacturing Demonstration System
Integrated with ROS2, FIWARE, and AR Visualization
            </field>
        </record>

        <!-- Set default list limits -->
        <record id="base.default_user" model="res.users">
            <field name="company_id" ref="base.main_company"/>
        </record>
    </data>
</odoo>
