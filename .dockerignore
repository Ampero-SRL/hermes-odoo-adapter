# Keep the Docker build context lean — only the things the Dockerfile
# actually `COPY`s should be sent to the daemon. Especially important
# after a fresh clone where `.env` (with potentially-private values) is
# created by the reviewer.

# Version control + tooling
.git/
.gitignore
.gitattributes
.github/

# Local secrets / runtime state
.env
.env.local
.env.*.local
*.log
logs/

# Python cache + virtual envs
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
.venv*/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Big artefacts not needed at build time
media/screenshots/*.png
media/demo.gif
media/demo.mp4

# Test outputs + node modules (if any creep in)
node_modules/
test-results/
playwright-report/
.playwright-mcp/

# Docker context already includes the in-tree compose / config we need;
# only exclude the docker-compose stack data dirs (host-mounted volumes).
docker/odoo-mock/__pycache__/
