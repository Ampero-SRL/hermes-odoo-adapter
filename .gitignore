# Project specific
logs/
# Generic data/ is gitignored to catch runtime / state directories,
# but the Odoo mock + Odoo addons ship seed data that MUST be tracked
# so the demo compose builds from a fresh clone (D4 reproducibility).
data/
!docker/odoo-mock/data/
!docker/odoo-mock/data/**
!docker/odoo-addons/**/data/
!docker/odoo-addons/**/data/**
!docker/odoo/custom_addons/**/data/
!docker/odoo/custom_addons/**/data/**
*.db

# Test / browser-automation / cast artefacts that occasionally leak from
# tooling runs (codex sessions, playwright captures, vhs renders).
.playwright-mcp/
playwright-report/
test-results/
*.cast
# …but DO ship the canonical demo recording (media/demo.cast) — it's a
# D4 deliverable per media/video_link.md, captured 2026-06-11 by running
# `asciinema rec -c 'bash scripts/demo_walkthrough.sh' media/demo.cast`
# against a fresh demo stack.
!media/demo.cast
media/demo.gif
media/demo.mp4

# The rendered D4 docx is the submission artefact, not source — render
# it on demand with:
#   pandoc docs/D4_REPORT_DRAFT.md \
#     --reference-doc="D4 - Shareable HRI Modules.docx" \
#     -o docs/D4_HERMES_Odoo_Adapter.docx
# Committing it creates drift against the markdown source of truth.
docs/D4_HERMES_Odoo_Adapter.docx

# Local configuration overrides
.env.local
docker-compose.override.yml

# Temporary files
tmp/
temp/
